# Arc Readiness Checker - environment configuration
# All Arc Testnet sources used today are PUBLIC and require NO keys.
# These vars exist so the endpoint seam stays server-only and key-safe
# if a future source needs authentication.

# Arc Testnet JSON-RPC endpoint (public, no auth)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Arc Testnet explorer base (public Blockscout API)
ARC_EXPLORER_BASE=https://testnet.arcscan.app

# Optional: cache TTL (seconds) for source fetches
ARC_CACHE_TTL_SECONDS=60
